# =========================================================
#  De'Vora environment config
#  Copy this file to ".env.local" and fill in your values.
#  The site runs in DEMO mode (local data + demo login) until
#  you add a real Firebase apiKey below.
# =========================================================

# ---- Firebase (free Spark plan) ----
# Get these from console.firebase.google.com → Project settings → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Store settings ----
# Where customers pay (UPI ID). Placeholder until you add yours.
NEXT_PUBLIC_UPI_ID=devora.payments@upi
# WhatsApp number that receives orders (digits only, with country code).
NEXT_PUBLIC_WHATSAPP_NUMBER=917249044809
# Email allowed to manage products at /admin (your Google account email).
NEXT_PUBLIC_ADMIN_EMAIL=
